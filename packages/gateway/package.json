{
  "name": "@claimgenie/gateway",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "predev": "pnpm --filter @claimgenie/shared build && pnpm --filter @claimgenie/auth build",
    "dev": "ts-node-dev --no-deprecation --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@claimgenie/auth": "workspace:*",
    "@claimgenie/shared": "workspace:*",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "express-session": "^1.18.1",
    "http-proxy-middleware": "^3.0.0",
    "express-rate-limit": "^7.0.0",
    "compression": "^1.7.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/compression": "^1.7.0",
    "@types/express": "^4.17.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
