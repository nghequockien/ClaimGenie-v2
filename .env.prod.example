# ─── PRODUCTION environment variables ────────────────────────────────────────
# Copy this to .env.prod — NEVER commit real secrets

NODE_ENV=production
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_PROVIDER=postgresql
POSTGRES_USER=masuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=insurance_mas
DATABASE_URL=postgresql://masuser:CHANGE_ME_STRONG_PASSWORD@postgres:5432/insurance_mas

# ── LLM provider (global defaults) ───────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
# LLM_CONFIG_FILE=/app/config/llm.config.json

# Provider credentials (set only what you use)
ANTHROPIC_API_KEY=sk-ant-your-production-key-here
# OPENAI_API_KEY=sk-openai-your-production-key
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# GEMINI_API_KEY=your-gemini-key

# ── Agent host names (Docker service names) ───────────────────────────────────
# Used by A2A (agent-to-agent) communication when agents need to reach each other
CLAIMS_RECEIVER_HOST=claims-receiver
OCR_PROCESSOR_HOST=ocr-processor
ICD_CONVERTER_HOST=icd-converter
CUSTOMER_VERIFICATION_HOST=customer-verification
FRAUD_DETECTION_HOST=fraud-detection
PAYMENT_GENERATOR_HOST=payment-generator

# ── A2A discovery + OAuth2 (client credentials) ─────────────────────────────
# Discovery
A2A_DISCOVERY_ENABLED=true
A2A_REGISTRY_URL=https://your-api-domain.com/api/registry/agents
A2A_DISCOVERY_CACHE_TTL_MS=60000

# Agent card auth metadata defaults (optional)
A2A_AUTH_MODE=oauth2_client_credentials
A2A_AUDIENCE=
A2A_REQUIRED_SCOPE=
A2A_TOKEN_ENDPOINT=https://your-api-domain.com/oauth2/token
A2A_TOKEN_ISSUER=https://your-api-domain.com
A2A_JWKS_URI=https://your-api-domain.com/.well-known/jwks.json
A2A_VALIDATE_JWT=true
A2A_CLOCK_TOLERANCE_SEC=10
A2A_ENFORCE_FROM_AGENT_BINDING=true
A2A_REQUIRE_CLIENT_AGENT_MAPPING=true
A2A_OAUTH_ACCESS_TOKEN_TTL_SEC=300

# Provide RSA keys for stable JWT signing (PEM values, multiline escaped with \n)
# A2A_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# A2A_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# OAuth client identity -> Agent mapping (receiver-side)
# Option A: JSON object map
# A2A_CLIENT_AGENT_MAP_JSON={"claims-receiver-client":"CLAIMS_RECEIVER","ocr-client":"OCR_PROCESSOR"}
# Option B: per-agent variables
# A2A_CLIENT_ID_CLAIMS_RECEIVER=claims-receiver-client
# A2A_CLIENT_IDS_OCR_PROCESSOR=ocr-client,ocr-client-alt

# OAuth client credentials issued by gateway /oauth2/token (recommended)
# A2A_CLIENT_ID_CLAIMS_RECEIVER=claims-receiver-client
# A2A_CLIENT_SECRET_CLAIMS_RECEIVER=change-me-claims
# A2A_CLIENT_ID_OCR_PROCESSOR=ocr-processor-client
# A2A_CLIENT_SECRET_OCR_PROCESSOR=change-me-ocr
# A2A_CLIENT_ID_ICD_CONVERTER=icd-converter-client
# A2A_CLIENT_SECRET_ICD_CONVERTER=change-me-icd
# A2A_CLIENT_ID_CUSTOMER_VERIFICATION=customer-verification-client
# A2A_CLIENT_SECRET_CUSTOMER_VERIFICATION=change-me-customer
# A2A_CLIENT_ID_FRAUD_DETECTION=fraud-detection-client
# A2A_CLIENT_SECRET_FRAUD_DETECTION=change-me-fraud
# A2A_CLIENT_ID_PAYMENT_GENERATOR=payment-generator-client
# A2A_CLIENT_SECRET_PAYMENT_GENERATOR=change-me-payment

# OAuth2 client credentials used by each agent when calling other agents
A2A_OAUTH_CLIENT_ID=
A2A_OAUTH_CLIENT_SECRET=
A2A_OAUTH_CLIENT_AUTH=client_secret_post
A2A_OAUTH_TIMEOUT_MS=5000

# Optional target-specific OAuth overrides (suffix with target AgentName)
# A2A_OAUTH_CLIENT_ID_OCR_PROCESSOR=
# A2A_OAUTH_CLIENT_SECRET_OCR_PROCESSOR=
# A2A_OAUTH_SCOPE_OCR_PROCESSOR=a2a.invoke.ocr_processor
# A2A_OAUTH_AUDIENCE_OCR_PROCESSOR=OCR_PROCESSOR
# A2A_OAUTH_TOKEN_ENDPOINT_OCR_PROCESSOR=https://idp.yourdomain.com/oauth2/token

# Transitional fallback bearer token (only if OAuth endpoint is not ready yet)
# A2A_BEARER_TOKEN=

# ── Note: Per-agent LLM configuration ─────────────────────────────────────────
# Agent-specific LLM settings (provider, model, temperature, maxTokens, systemPrompt)
# are now stored in the database (AgentConfig table) and configured via the UI.
# See AGENT_CONFIG_DATABASE.md for details.
# Environment variables below are for global defaults only.

# ── Ports ─────────────────────────────────────────────────────────────────────
GATEWAY_PORT=4000

# ── Upload & storage ──────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://yourdomain.com

# ── Auth / SSO (Google + LinkedIn) ───────────────────────────────────────────
# Comma-separated admin emails. Matching users become ADMIN at sign-in.
ADMIN_EMAILS=admin@yourdomain.com
SESSION_SECRET=change-me-prod-session-secret
UI_URL=https://yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-api-domain.com/api/auth/google/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-api-domain.com/api/auth/linkedin/callback

# ── Docker image registry (for CI/CD) ─────────────────────────────────────────
REGISTRY=ghcr.io/your-org/insurance-mas
IMAGE_TAG=latest
