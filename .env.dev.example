# ─── DEVELOPMENT environment variables ───────────────────────────────────────
# Copy this to .env.dev and fill in your ANTHROPIC_API_KEY

NODE_ENV=development
LOG_LEVEL=DEBUG

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_PROVIDER tells the runtime adapter which driver to use.
# Prisma 7: the schema + prisma.config.ts are set by `node infrastructure/scripts/db-schema.js dev`
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev-data/dev.db

# ── LLM provider (global defaults) ───────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
# LLM_CONFIG_FILE=./config/llm.config.json

# Provider credentials (set only what you use)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-openai-your-key-here
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# GEMINI_API_KEY=your-gemini-key

# ── Ports ─────────────────────────────────────────────────────────────────────
GATEWAY_PORT=4000

# ── Agent host overrides (A2A communication) ─────────────────────────────────
# For local development, all agents run on localhost
CLAIMS_RECEIVER_HOST=localhost
OCR_PROCESSOR_HOST=localhost
ICD_CONVERTER_HOST=localhost
CUSTOMER_VERIFICATION_HOST=localhost
FRAUD_DETECTION_HOST=localhost
PAYMENT_GENERATOR_HOST=localhost

# ── A2A discovery + OAuth2 (client credentials) ─────────────────────────────
# Discovery
A2A_DISCOVERY_ENABLED=true
A2A_REGISTRY_URL=http://localhost:4000/api/registry/agents
A2A_DISCOVERY_CACHE_TTL_MS=60000

# Agent card auth metadata defaults (optional)
A2A_AUTH_MODE=oauth2_client_credentials
A2A_AUDIENCE=
A2A_REQUIRED_SCOPE=
A2A_TOKEN_ENDPOINT=
A2A_TOKEN_ISSUER=
A2A_JWKS_URI=
A2A_VALIDATE_JWT=false
A2A_CLOCK_TOLERANCE_SEC=10
A2A_ENFORCE_FROM_AGENT_BINDING=true
A2A_REQUIRE_CLIENT_AGENT_MAPPING=true

# OAuth client identity -> Agent mapping (receiver-side)
# Option A: JSON object map
# A2A_CLIENT_AGENT_MAP_JSON={"claims-receiver-client":"CLAIMS_RECEIVER","ocr-client":"OCR_PROCESSOR"}
# Option B: per-agent variables
# A2A_CLIENT_ID_CLAIMS_RECEIVER=claims-receiver-client
# A2A_CLIENT_IDS_OCR_PROCESSOR=ocr-client,ocr-client-alt

# OAuth2 client credentials used by each agent when calling other agents
A2A_OAUTH_CLIENT_ID=
A2A_OAUTH_CLIENT_SECRET=
A2A_OAUTH_CLIENT_AUTH=client_secret_post
A2A_OAUTH_TIMEOUT_MS=5000

# Optional target-specific OAuth overrides (suffix with target AgentName)
# A2A_OAUTH_CLIENT_ID_OCR_PROCESSOR=
# A2A_OAUTH_CLIENT_SECRET_OCR_PROCESSOR=
# A2A_OAUTH_SCOPE_OCR_PROCESSOR=a2a.invoke.ocr_processor
# A2A_OAUTH_AUDIENCE_OCR_PROCESSOR=OCR_PROCESSOR
# A2A_OAUTH_TOKEN_ENDPOINT_OCR_PROCESSOR=https://idp.example.com/oauth2/token

# Transitional fallback bearer token (only if OAuth endpoint is not ready yet)
# A2A_BEARER_TOKEN=

# ── Note: Per-agent LLM configuration ─────────────────────────────────────────
# Agent-specific LLM settings (provider, model, temperature, maxTokens, systemPrompt)
# are now stored in the database (AgentConfig table) and configured via the UI.
# See AGENT_CONFIG_DATABASE.md for details.
# Environment variables below are for global defaults only.

# ── MCP service URLs ─────────────────────────────────────────────────────────
# Run each mock server with: pnpm --filter @claimgenie/mcp-verification dev
# Agents fall back to AI simulation when the MCP server is unreachable.
VERIFICATION_MCP_URL=http://localhost:5004/mcp
# ICD_MCP_URL=http://localhost:5003/mcp
# FRAUD_MCP_URL=http://localhost:5005/mcp
# OCR_MCP_URL=http://localhost:5002/mcp

# ── Upload directory ──────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Auth / SSO (Google + LinkedIn) ───────────────────────────────────────────
# Comma-separated admin emails. Matching users become ADMIN at sign-in.
ADMIN_EMAILS=admin@yourcompany.com
SESSION_SECRET=change-me-dev-session-secret
UI_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/auth/linkedin/callback
